# --- Neon Postgres (pooled connection string) ---
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- better-auth ---
# 32+ char random secret (openssl rand -base64 32)
BETTER_AUTH_SECRET=
# Public origin (no trailing slash). e.g. https://app.dreamcrm.com or http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# --- Vercel Blob ---
BLOB_READ_WRITE_TOKEN=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Twilio (marketing SMS via A2P 10DLC) ---
# Required for the SMS channel in Recall & Outreach. Until A2P 10DLC brand +
# campaign are approved by US carriers (5-14 business days), the SMS channel
# stays disabled in the UI even if these are set.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
