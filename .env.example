# ─── Database (AWS RDS Postgres, or local) ───
# Prod: the RDS connection string (stored in Secrets Manager, not here).
# Local: a local Postgres. node-postgres driver; SSL handled in lib/db.
DATABASE_URL=postgres://user:password@localhost:5432/dreamcrm

# ─── better-auth ───
# 32+ char random secret (openssl rand -base64 32)
BETTER_AUTH_SECRET=
# Canonical origin, no trailing slash. Prod: https://dreamcreatestudio.com
BETTER_AUTH_URL=http://localhost:3000

# ─── App (NEXT_PUBLIC_* are inlined at BUILD time — pass as Docker build args) ───
# Used for invite links, Stripe return URLs, review/marketing/notification
# emails, Gmail OAuth redirects. Must be set when the image is built.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Apex domain for clinic public sites ({slug}.<domain>). Default is correct.
NEXT_PUBLIC_SITE_DOMAIN=dreamcreatestudio.com
# Leave unset until wildcard DNS + CDN are live (keeps clinic URLs path-based).
# NEXT_PUBLIC_SITE_USE_SUBDOMAIN=true

# ─── Storage (S3 in prod; Vercel Blob fallback) ───
STORAGE_DRIVER=s3
S3_BUCKET=dreamcrm-uploads-prod
S3_REGION=us-east-1
# Optional CloudFront/custom-domain origin for public object URLs.
# S3_PUBLIC_BASE_URL=
# Only needed when STORAGE_DRIVER is unset/blob:
# BLOB_READ_WRITE_TOKEN=

# ─── Email (SES in prod via IAM; Resend fallback) ───
EMAIL_DRIVER=ses
# SES_REGION defaults to AWS_REGION; optional event-tracking config set:
# SES_CONFIGURATION_SET=
# Only needed when EMAIL_DRIVER=resend:
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# ─── AI (Bedrock in prod via IAM; Anthropic direct fallback) ───
AI_DRIVER=bedrock
# Only needed when AI_DRIVER=anthropic:
ANTHROPIC_API_KEY=

# ─── AWS (App Runner injects credentials via the instance role) ───
AWS_REGION=us-east-1

# ─── Cron / admin routes (CRON_SECRET guards /api/cron + /api/admin/*) ───
CRON_SECRET=

# ─── Stripe ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_ANNUAL=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_ANNUAL=

# ─── Google OAuth + Gmail push (Pub/Sub) ───
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GMAIL_PUBSUB_TOPIC=
GMAIL_PUBSUB_SA_EMAIL=
GMAIL_PUBSUB_AUDIENCE=

# ─── Misc ───
# Encrypts stored Gmail OAuth tokens at rest (openssl rand -base64 32)
EMAIL_ENCRYPTION_KEY=
# Signs marketing open/click/unsub tokens
MARKETING_TOKEN_SECRET=
# CAN-SPAM physical mailing address shown in marketing email footers
MARKETING_POSTAL_ADDRESS=

# ─── SMS (later phase: AWS End User Messaging — not yet wired) ───
# A2P 10DLC brand + campaign registration required before the SMS channel
# can be enabled in the UI.
